# Billing (set to 0 to disable Stripe and hide billing routes/UI)
BILLING_ENABLED=1

# Stripe billing (required when BILLING_ENABLED=1)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PLAN_NAME=Pro
# Set to 0 to disable Stripe Tax automatic calculation at Checkout
STRIPE_TAX_ENABLED=1
